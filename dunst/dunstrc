[global]
    monitor = 0
    follow = mouse

    # Geometry
    width = (300, 460)
    height = (0, 200)
    origin = top-right
    offset = (14, 50)
    scale = 0
    notification_limit = 5

    # Layout
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 10
    frame_width = 2
    frame_color = "#504945"
    gap_size = 6
    corner_radius = 10
    separator_height = 2
    separator_color = frame

    # Text
    font = Overpass 13
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    word_wrap = yes
    ellipsize = middle
    show_age_threshold = 60
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = no

    # Icons
    icon_theme = "Papirus-Dark,Adwaita"
    enable_recursive_icon_lookup = true
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    # Idle
    idle_threshold = 120

    # Mouse
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1d2021"
    foreground = "#a89984"
    frame_color = "#504945"
    timeout = 4

[urgency_normal]
    background = "#1d2021"
    foreground = "#ebdbb2"
    frame_color = "#83a598"
    timeout = 8

[urgency_critical]
    background = "#282828"
    foreground = "#fb4934"
    frame_color = "#fb4934"
    timeout = 0
