{
  "layer": "top",
  "position": "top",
  "height": 36,
  "spacing": 0,

  "modules-left": [
    "hyprland/workspaces",
    "custom/special",
    "hyprland/window"
  ],
  "modules-center": [],
  "modules-right": [
    "group/hardware",
    "wireplumber",
    "custom/pacman",
    "clock",
    "tray",
    "custom/notification",
    "custom/power"
  ],

  "hyprland/workspaces": {
    "format": "{id}",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": {
      "*": 6
    }
  },

  "hyprland/window": {
    "max-length": 60,
    "separate-outputs": true
  },

  "custom/special": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/special-ws.sh",
    "return-type": "json",
    "escape": true,
    "tooltip": true,
    "on-click": "hyprctl dispatch togglespecialworkspace"
  },

  "group/hardware": {
    "orientation": "horizontal",
    "modules": [
      "cpu",
      "memory",
      "temperature",
      "battery"
    ]
  },

  "cpu": {
    "interval": 2,
    "format": "َ°»  {usage}%",
    "tooltip": true
  },

  "memory": {
    "format": "َ°چ› {}%"
  },

  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon5/temp1_input",
    "critical-threshold": 70,
    "interval": 2,
    "format": "َ°”ڈ {temperatureC}آ°C"
  },

  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "format-plugged": "َ°ڑ¥ {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
    "interval": 10
  },

  "wireplumber": {
    "scroll-step": 0.5,
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں {volume}%",
    "format-icons": {
      "headphone": "َ°‹‹",
      "headset": "َ°‹ژ",
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "on-click": "pavucontrol"
  },

  "custom/pacman": {
    "format": "َ°ڈ— {}",
    "interval": 3600,
    "exec": "checkupdates | wc -l",
    "exec-if": "[ $(checkupdates | wc -l) -gt 0 ]",
    "on-click": "kitty fish -c \"sudo pacman -Suy && pkill -SIGRTMIN+8 waybar\"",
    "signal": 8
  },

  "clock": {
    "format": "َ°ƒ°  {:%a %d %b  %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "tray": {
    "spacing": 8
  },

  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "َ±…«",
      "none": "َ°‚ڑ",
      "dnd-notification": "َ±…«",
      "dnd-none": "َ°‚›",
      "inhibited-notification": "َ±…«",
      "inhibited-none": "َ°‚ڑ",
      "dnd-inhibited-notification": "َ±…«",
      "dnd-inhibited-none": "َ°‚›"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "custom/power": {
    "format": "َ°گ¥",
    "tooltip": false,
    "on-click": "~/.config/waybar/power-menu.sh"
  }
}
